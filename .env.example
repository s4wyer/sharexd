USERS_FILE="users.json"

# generate these keys with `python3 -c "import secrets; print(secrets.token_hex(32))"`
# master key used for generating file deletion URLs and admin bypass
MASTER_KEY="SUPER_SECRET_MASTER_KEY_HERE"
# secret key for sessions (currently only used for the captcha sessions but will be more important in the future)
SECRET_KEY="SUPER_SECRET_KEY_HERE"

# make these blank to remove the donation text from the home page
DONATION_URL="https://ko-fi.com/s4wyer_"
DONATION_PLATFORM="ko-fi"

ABUSE_EMAIL="abuse@yourdomain.com"
ADMIN_HANDLE="your_handle"
GITHUB_URL="https://github.com/s4wyer/sharexd"
MAX_UPLOAD_MB=100
REMOVE_IMAGE_METADATA=true

# this project includes a tarpit (routes/tarpit.py) that generates
# fake data for malicous scrapers. disable it if you don't want it,
# mostly for fun
TARPIT_ENABLED=true

# storage configuration
# set to 's3' to use an S3-compatible backend, otherwise defaults to 'local'
STORAGE_BACKEND="local"

# S3 configuration (required if STORAGE_BACKEND="s3")
S3_BUCKET_NAME="your-bucket-name"
S3_ENDPOINT_URL="https://your-endpoint.com"
S3_ACCESS_KEY_ID="your_access_key"
S3_SECRET_ACCESS_KEY="your_secret_key"
S3_REGION="us-east-1"
